# =============================================================================
# Media Committee Portal — Environment / Config reference
# =============================================================================
# This is the MASTER documentation of every config value the system needs.
# Copy the relevant blocks into the right place (see notes per block) and fill
# in real values. NEVER commit real secrets — only this .example file.
#
# Quick map of where each block actually lives:
#   - Firebase WEB config  -> web/js/firebase-config.js   (public, safe to ship)
#   - Functions runtime    -> functions/.env              (copy from functions/.env.example)
#   - Functions secrets    -> functions/.secret.local     (emulator) / Firebase Secret Manager (prod)
#   - Admin / Calendar SA  -> a JSON file referenced by GOOGLE_APPLICATION_CREDENTIALS
# =============================================================================


# -----------------------------------------------------------------------------
# 1) Firebase Web SDK config  (lives in web/js/firebase-config.js)
# -----------------------------------------------------------------------------
# These are PUBLIC client values (not secrets) — they ship in the browser bundle.
# Get them from: Firebase Console -> Project settings -> Your apps -> Web app.
FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=000000000000
FIREBASE_APP_ID=1:000000000000:web:abcdef0123456789


# -----------------------------------------------------------------------------
# 2) Auth domain restriction  (config-driven — never hardcode in logic)
# -----------------------------------------------------------------------------
# Comma-separated list of allowed Google Workspace domains. Sign-ins whose email
# domain is not in this list are rejected (front end + Cloud Functions enforce).
# Confirmed for this deployment: iimsirmaur.ac.in
# Used by: web/js/firebase-config.js (ALLOWED_AUTH_DOMAINS) and functions/.env.
ALLOWED_AUTH_DOMAINS=iimsirmaur.ac.in


# -----------------------------------------------------------------------------
# 3) Email provider — Resend  (functions secret + runtime)
# -----------------------------------------------------------------------------
# The email layer is behind a swappable interface (see functions src in Phase 7).
# Resend was selected. RESEND_API_KEY is a SECRET; EMAIL_FROM is a runtime param.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Media Committee <media@iimsirmaur.ac.in>
# Optional: where bounce/replies go, and a global BCC for auditing (leave blank to skip)
EMAIL_REPLY_TO=
EMAIL_BCC=


# -----------------------------------------------------------------------------
# 4) Admin SDK service account  (seed script / local tooling)
# -----------------------------------------------------------------------------
# Path to a service-account JSON with Firestore access. Only needed when running
# the seed script or admin tooling against a REAL project (NOT needed for the
# emulator — the emulator uses a fake project). Keep the JSON out of git.
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccount.json


# -----------------------------------------------------------------------------
# 5) Google Calendar  (Phase 11 — currently STUBBED, values not required yet)
# -----------------------------------------------------------------------------
# Free/busy checks + invites via a service account with domain-wide delegation.
# Admin grants delegation in the Workspace Admin console (see README).
# Leave blank for v1 — the calendar layer is stubbed until Phase 11.
CALENDAR_SERVICE_ACCOUNT_JSON=./calendar-service-account.json
# The Workspace user the service account impersonates for free/busy + invites
# (must be a real mailbox in the institute domain, e.g. an ops/automation user):
GOOGLE_CALENDAR_DELEGATED_SUBJECT=media-bot@iimsirmaur.ac.in


# -----------------------------------------------------------------------------
# 6) Emulator (local dev) — informational
# -----------------------------------------------------------------------------
# The seed script and any admin tooling talk to the emulator when these are set.
# Ports match firebase.json. You normally don't edit these.
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
# A throwaway project id used by the emulator (any value works locally):
GCLOUD_PROJECT=mcc-portal-local
