{
  "name": "mcc-portal-functions",
  "version": "0.1.0",
  "private": true,
  "description": "Media Committee Portal — Cloud Functions engine (event-driven workflow).",
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "dependencies": {
    "firebase-admin": "^12.6.0",
    "firebase-functions": "^5.1.1",
    "googleapis": "^144.0.0",
    "resend": "^4.0.1"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
