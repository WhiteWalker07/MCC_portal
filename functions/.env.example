# =============================================================================
# Functions runtime config  ->  copy to functions/.env  (git-ignored)
# =============================================================================
# Cloud Functions v2 auto-loads functions/.env for NON-SECRET params.
# SECRETS (RESEND_API_KEY) go in functions/.secret.local for the emulator, and
# in Firebase Secret Manager for production:
#     firebase functions:secrets:set RESEND_API_KEY
#
# See the root .env.example for the full explanation of every value.

# Auth domain restriction (comma-separated). Confirmed: iimsirmaur.ac.in
ALLOWED_AUTH_DOMAINS=iimsirmaur.ac.in

# Email (Resend) — non-secret bits here; the API key is a secret (see above).
EMAIL_FROM=Media Committee <media@iimsirmaur.ac.in>
EMAIL_REPLY_TO=
EMAIL_BCC=

# Calendar (Phase 11 — stubbed for v1; leave blank until then)
GOOGLE_CALENDAR_DELEGATED_SUBJECT=

# -----------------------------------------------------------------------------
# functions/.secret.local  (emulator secrets — create this file, git-ignored)
# -----------------------------------------------------------------------------
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
