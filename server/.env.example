# ── MCC Portal server — environment ────────────────────────────────────────
# Copy to server/.env for local dev (loaded via dotenv). On Render, set these in
# the service's Environment tab instead.

# MongoDB Atlas connection string (free M0 cluster). Local dev can use
# mongodb://127.0.0.1:27017
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=mcc_portal

# Long random string — signs the session cookie.
SESSION_SECRET=change-me-to-a-long-random-string

# Google OAuth 2.0 Web client (Google Cloud Console → Credentials).
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxx
# Must EXACTLY match an Authorized redirect URI on the OAuth client.
# Local:  http://localhost:8080/auth/google/callback
# Render: https://<your-service>.onrender.com/auth/google/callback
OAUTH_CALLBACK_URL=http://localhost:8080/auth/google/callback

# The frontend origin (Vercel URL). Used for CORS + the post-login redirect.
# Local: http://localhost:3000
CLIENT_ORIGIN=http://localhost:3000

# Comma-separated allowed Google Workspace domains for sign-in.
ALLOWED_DOMAINS=iimsirmaur.ac.in

# Shared secret the cron sends in the x-cron-secret header.
CRON_SECRET=change-me-too

# Server port (Render sets PORT automatically).
PORT=8080

# ── Optional integrations (auto-fallback to logging stubs when unset) ────────
# RESEND_API_KEY=re_xxx
# EMAIL_FROM=Media Committee <onboarding@resend.dev>
# EMAIL_REPLY_TO=
# EMAIL_BCC=
# CALENDAR_SERVICE_ACCOUNT_JSON=  (path to JSON file or inline JSON)
